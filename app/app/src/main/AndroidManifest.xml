<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to query all installed packages for the app drawer -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Required for TAPO Labs (AI LLM API calls) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for the uninstall action in the app context menu -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <application
        android:name=".TAPOLauncherApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KDELauncher"
        android:largeHeap="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|keyboard|keyboardHidden"
            android:windowSoftInputMode="adjustResize">

            <!--
                Being a HOME-category launcher, the system navigates back to this
                activity when the user presses Home.  "singleTask" ensures there
                is only one instance of the launcher activity at any time.
                No priority attribute — priority="1" can interfere with system
                gesture resolution (assistant trigger, navigation) on some devices.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Makes the app also appear in the app drawer as a regular app icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            DefaultLauncherActivity: a transparent trampoline activity that opens
            Android's "Choose Default Home App" system settings screen.
            Launched from the launcher's own settings panel when the user taps
            "Set as Default Launcher".
        -->
        <activity
            android:name=".SetDefaultLauncherActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />


    </application>

</manifest>
